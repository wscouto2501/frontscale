#!/bin/bash

set -e

echo "🚀 Setup Frontscale (modo completo)"

# ================================
# 📥 VARIÁVEIS DE AMBIENTE
# ================================
echo ""
echo "📋 Cole TODAS as variáveis (formato: export VAR=valor)"
echo "👉 Quando terminar, pressione CTRL + D"
echo ""

ENV_INPUT=$(cat)

# limpa espaços e pega export
CLEAN_ENV=$(echo "$ENV_INPUT" | sed 's/^[[:space:]]*//' | grep '^export ')

if [ -z "$CLEAN_ENV" ]; then
  echo "❌ Nenhuma variável válida encontrada"
  exit 1
fi

echo "💾 Salvando variáveis no ~/.bashrc..."

# remove duplicadas
while IFS= read -r line; do
  VAR_NAME=$(echo "$line" | cut -d '=' -f1 | sed 's/export //')
  sed -i "/^export $VAR_NAME=/d" ~/.bashrc || true
done <<< "$CLEAN_ENV"

# adiciona no final
echo "" >> ~/.bashrc
echo "# FRONT SCALE ENV" >> ~/.bashrc
echo "$CLEAN_ENV" >> ~/.bashrc

# ================================
# ⚡ APLICAR IMEDIATAMENTE
# ================================
echo "$CLEAN_ENV" > /tmp/frontscale_env.sh
source /tmp/frontscale_env.sh

# ================================
# 🧪 VALIDAÇÃO
# ================================
if [ -z "$DATABASE_URL" ]; then
  echo "❌ DATABASE_URL não definido"
  exit 1
fi

echo "✅ Variáveis carregadas com sucesso!"

# ================================
# 📥 MIGRATION.SQL
# ================================
echo ""
echo "🧬 Cole o conteúdo do migration.sql"
echo "👉 Quando terminar, pressione CTRL + D"
echo ""


cat <<'EOF' > migration.sql
CREATE SCHEMA "public";
CREATE SCHEMA "stripe";
CREATE TYPE "stripe"."pricing_type" AS ENUM('one_time', 'recurring');
CREATE TYPE "stripe"."pricing_tiers" AS ENUM('graduated', 'volume');
CREATE TYPE "stripe"."subscription_status" AS ENUM('trialing', 'active', 'canceled', 'incomplete', 'incomplete_expired', 'past_due', 'unpaid', 'paused');
CREATE TYPE "stripe"."invoice_status" AS ENUM('draft', 'open', 'paid', 'uncollectible', 'void', 'deleted');
CREATE TYPE "stripe"."subscription_schedule_status" AS ENUM('not_started', 'active', 'completed', 'released', 'canceled');
CREATE TABLE "app_settings" (
	"id" serial PRIMARY KEY,
	"key" text NOT NULL CONSTRAINT "app_settings_key_unique" UNIQUE,
	"value" text NOT NULL,
	"updated_at" timestamp DEFAULT now() NOT NULL
);
CREATE TABLE "client_tags" (
	"client_id" integer,
	"tag_id" integer,
	CONSTRAINT "client_tags_pkey" PRIMARY KEY("client_id","tag_id")
);
CREATE TABLE "clients" (
	"id" serial PRIMARY KEY,
	"user_id" integer NOT NULL,
	"whatsapp_number_id" integer,
	"name" text NOT NULL,
	"phone" text,
	"status" text DEFAULT 'active' NOT NULL,
	"temperature" text,
	"notes" text,
	"created_at" timestamp DEFAULT now() NOT NULL,
	"email" text,
	"company" text,
	"document" text,
	"address" text,
	"lead_source" text,
	"tags" text,
	"lid" text
);
CREATE TABLE "conversation_history" (
	"id" serial PRIMARY KEY,
	"whatsapp_number_id" integer NOT NULL,
	"remote_jid" text NOT NULL,
	"role" text NOT NULL,
	"content" text NOT NULL,
	"created_at" timestamp DEFAULT now() NOT NULL
);
CREATE TABLE "follow_up_config_kb_groups" (
	"follow_up_config_id" integer,
	"kb_group_id" integer,
	CONSTRAINT "follow_up_config_kb_groups_follow_up_config_id_kb_group_id_pk" PRIMARY KEY("follow_up_config_id","kb_group_id")
);
CREATE TABLE "follow_up_configs" (
	"id" serial PRIMARY KEY,
	"user_id" integer NOT NULL,
	"whatsapp_number_id" integer NOT NULL,
	"days_since_last_contact" integer DEFAULT 3 NOT NULL,
	"contact_start_time" text DEFAULT '09:00' NOT NULL,
	"contact_end_time" text DEFAULT '18:00' NOT NULL,
	"min_interval_minutes" integer DEFAULT 30 NOT NULL,
	"max_interval_minutes" integer DEFAULT 90 NOT NULL,
	"enabled" boolean DEFAULT false NOT NULL,
	"created_at" timestamp DEFAULT now() NOT NULL,
	"updated_at" timestamp DEFAULT now() NOT NULL,
	"kb_active_days" integer DEFAULT 7 NOT NULL,
	"kb_renew_on_reply" boolean DEFAULT false NOT NULL,
	"fire_once_per_contact" boolean DEFAULT true NOT NULL,
	"tag_filter_ids" text DEFAULT '[]' NOT NULL,
	"tag_filter_mode" text DEFAULT 'disabled' NOT NULL,
	"tags_to_add_after_send" text DEFAULT '[]' NOT NULL,
	"tags_to_remove_after_send" text DEFAULT '[]' NOT NULL,
	"tag_include_ids" text DEFAULT '[]' NOT NULL,
	"tag_include_mode" text DEFAULT 'any_of' NOT NULL,
	"tag_exclude_ids" text DEFAULT '[]' NOT NULL,
	"tag_exclude_mode" text DEFAULT 'any_of' NOT NULL
);
CREATE TABLE "follow_up_sent_log" (
	"id" serial PRIMARY KEY,
	"config_id" integer NOT NULL,
	"whatsapp_number_id" integer NOT NULL,
	"client_phone" text NOT NULL,
	"sent_at" timestamp DEFAULT now() NOT NULL
);
CREATE TABLE "knowledge_base" (
	"id" serial PRIMARY KEY,
	"user_id" integer NOT NULL,
	"name" text NOT NULL,
	"type" text NOT NULL,
	"size" integer DEFAULT 0 NOT NULL,
	"content" text,
	"file_path" text,
	"created_at" timestamp DEFAULT now() NOT NULL,
	"group_id" integer
);
CREATE TABLE "knowledge_base_groups" (
	"id" serial PRIMARY KEY,
	"user_id" integer NOT NULL,
	"name" text NOT NULL,
	"created_at" timestamp DEFAULT now() NOT NULL
);
CREATE TABLE "reminders" (
	"id" serial PRIMARY KEY,
	"user_id" integer NOT NULL,
	"client_id" integer,
	"title" text NOT NULL,
	"description" text,
	"due_at" timestamp NOT NULL,
	"completed" boolean DEFAULT false NOT NULL,
	"created_at" timestamp DEFAULT now() NOT NULL,
	"type" text DEFAULT 'reminder' NOT NULL,
	"followup_message" text,
	"tags_to_add_after_send" integer[],
	"tags_to_remove_after_send" integer[]
);
CREATE TABLE "tags" (
	"id" serial PRIMARY KEY,
	"user_id" integer NOT NULL,
	"name" text NOT NULL,
	"color" text DEFAULT '#6366f1' NOT NULL,
	"created_at" timestamp DEFAULT now() NOT NULL
);
CREATE TABLE "users" (
	"id" serial PRIMARY KEY,
	"email" text NOT NULL CONSTRAINT "users_email_unique" UNIQUE,
	"password_hash" text,
	"name" text NOT NULL,
	"google_id" text CONSTRAINT "users_google_id_unique" UNIQUE,
	"business_context" text,
	"created_at" timestamp DEFAULT now() NOT NULL,
	"stripe_customer_id" text,
	"subscription_id" text,
	"subscription_status" text DEFAULT 'none' NOT NULL,
	"language" text,
	"subscription_renewal_date" timestamp,
	"subscription_start_date" timestamp,
	"max_kb_contexts" integer DEFAULT 5 NOT NULL,
	"numero_kb_enabled" boolean DEFAULT true NOT NULL
);
CREATE TABLE "webhook_context" (
	"id" serial PRIMARY KEY,
	"webhook_id" integer NOT NULL,
	"phone" text NOT NULL,
	"last_contact_at" timestamp DEFAULT now() NOT NULL,
	"expires_at" timestamp NOT NULL,
	"raw_json" text
);
CREATE TABLE "webhook_history" (
	"id" serial PRIMARY KEY,
	"webhook_id" integer NOT NULL,
	"received_at" timestamp DEFAULT now() NOT NULL,
	"raw_json" text NOT NULL,
	"phone" text,
	"generated_message" text,
	"status" text DEFAULT 'received' NOT NULL,
	"processing_attempts" integer DEFAULT 0 NOT NULL,
	"error_message" text
);
CREATE TABLE "webhook_queue" (
	"id" serial PRIMARY KEY,
	"webhook_id" integer NOT NULL,
	"history_id" integer,
	"raw_json" text,
	"phone" text,
	"message" text,
	"scheduled_at" timestamp DEFAULT now() NOT NULL,
	"attempts" integer DEFAULT 0 NOT NULL,
	"status" text DEFAULT 'awaiting_ai' NOT NULL,
	"created_at" timestamp DEFAULT now() NOT NULL
);
CREATE TABLE "webhooks" (
	"id" serial PRIMARY KEY,
	"user_id" integer NOT NULL,
	"name" text NOT NULL,
	"slug" text NOT NULL CONSTRAINT "webhooks_slug_key" UNIQUE,
	"secret_token" text,
