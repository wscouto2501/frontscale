	"interval_max" integer DEFAULT 5 NOT NULL,
	"context_days" integer DEFAULT 7 NOT NULL,
	"auto_renew_context" boolean DEFAULT false NOT NULL,
	"history_enabled" boolean DEFAULT true NOT NULL,
	"created_at" timestamp DEFAULT now() NOT NULL,
	"updated_at" timestamp DEFAULT now() NOT NULL,
	"kb21_ids" text DEFAULT '[]' NOT NULL,
	"kb22_ids" text DEFAULT '[]' NOT NULL,
	"kb22_json_context" boolean DEFAULT true NOT NULL,
	"kb_extraction_enabled" boolean DEFAULT false NOT NULL,
	"kb_extraction_id" integer,
	"kb22_json_context_answer" boolean DEFAULT false NOT NULL,
	"whatsapp_send_enabled" boolean DEFAULT true NOT NULL,
	"tags_to_add" text DEFAULT '[]' NOT NULL,
	"tags_to_remove" text DEFAULT '[]' NOT NULL
);
CREATE TABLE "whatsapp_number_knowledge_bases" (
	"id" serial PRIMARY KEY,
	"whatsapp_number_id" integer NOT NULL,
	"knowledge_base_group_id" integer NOT NULL
);
CREATE TABLE "whatsapp_numbers" (
	"id" serial PRIMARY KEY,
	"user_id" integer NOT NULL,
	"name" text NOT NULL,
	"phone" text,
	"status" text DEFAULT 'disconnected' NOT NULL,
	"sector" text,
